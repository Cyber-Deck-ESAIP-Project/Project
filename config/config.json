{
    "system": {
        "log_level": "DEBUG",
        "results_dir": "results",
        "logs_dir": "logs",
        "gemini_api_key": ""
    },
    "modules": {
        "lan_scan": {
            "enabled": true,
            "interface": "wlan0",
            "timeout": 30,
            "max_deep_scan_hosts": 30
        },
        "wifi_audit": {
            "enabled": true,
            "interface": "wlan0"
        },
        "bluetooth_recon": {
            "enabled": true,
            "interface": "hci0",
            "timeout": 20
        },
        "passive_monitor": {
            "enabled": true,
            "interface": "wlan0",
            "duration": 60
        },
        "arp_monitor": {
            "enabled": true,
            "interface": "wlan0",
            "duration": 120
        },
        "tls_audit": {
            "enabled": true,
            "default_target": ""
        },
        "hwmon_telemetry": {
            "enabled": true,
            "sampling_interval": 2,
            "sample_count": 30,
            "cpu_temp_threshold": 80,
            "battery_threshold": 20,
            "alert_on_throttle": true,
            "collect_power_draw": true,
            "performance_baseline_path": "logs/hw_perf_baseline.json"
        },
        "dns_monitor": {
            "enabled": true,
            "interface": "wlan0"
        },
        "cve_matcher": {
            "enabled": true
        }
    },
    "dashboard": {
        "port": 5050,
        "host": "0.0.0.0"
    },
    "api_keys": {
        "google_gemini_key": ""
    }
}